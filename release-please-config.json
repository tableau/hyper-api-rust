{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": false,
  "separate-pull-requests": false,
  "bump-minor-pre-major": true,
  "packages": {
    ".": {
      "release-type": "simple",
      "component": "hyper-api-rust",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "extra-files": [
        { "type": "toml", "path": "Cargo.toml", "jsonpath": "$.workspace.package.version" },
        { "type": "generic", "path": "hyperdb-api-core/Cargo.toml" },
        { "type": "generic", "path": "hyperdb-api/Cargo.toml" },
        { "type": "generic", "path": "hyperdb-api-derive/Cargo.toml" },
        { "type": "generic", "path": "hyperdb-mcp/Cargo.toml" }
      ]
    }
  }
}
